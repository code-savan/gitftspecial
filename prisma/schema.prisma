generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(cuid())
  name            String?
  email           String?    @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  username        String?    @unique
  accounts        Account[]
  sessions        Session[]

  batteryLevel    Int        @default(100) // Battery level (default 100)
  points          Int        @default(0)   // Activity points for rewards and tasks
  wallet          Float      @default(0.0) // Withdrawable amount
  referrerId      String?                // ID of the user's referrer
  refs            Int        @default(0)   // Number of referrals
  chancesLeft     Int        @default(3)   // Chances left to play (default 3)
  xoWins          Int        @default(0)   // Number of X/O game wins

  referralsByMe   Referral[] @relation("ReferredBy")  // Users referred by this user
  referralsToMe   Referral[] @relation("ReferredUser") // Referrals where this user is referred
}


model Referral {
  id               String    @id @default(cuid())
  referredById     String    // ID of the user who referred this user
  referredBy       User      @relation("ReferredBy", fields: [referredById], references: [id]) // Relation to the referrer
  referredUserId   String    // ID of the referred user
  referredUser     User      @relation("ReferredUser", fields: [referredUserId], references: [id]) // Relation to the referred user
  referredUserName String    // Username of the referred user
  referredUserImage String?  // Image of the referred user
  referredUserRefs Int       @default(0) // Referrals of the referred user
}


model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
